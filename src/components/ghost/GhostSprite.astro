---
// The spec's block-art sprite logo, verbatim.
interface Props {
    tone?: 'accent' | 'dim';
}

const { tone = 'accent' } = Astro.props;

const SPRITE = `  ▄██████▄
 ██████████
▐██  ██  ██▌
▐██████████▌
▐██████████▌
 ▀█▀▀██▀▀█▀`;
---

<figure class:list={['ghost-sprite', `tone-${tone}`]}>
    <pre aria-hidden="true">{SPRITE}</pre>
</figure>

<style>
    .ghost-sprite {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    pre {
        font-family: var(--ghost-font);
        line-height: 1.05;
    }

    .tone-accent pre {
        color: var(--ghost-accent);
    }

    .tone-dim pre {
        color: var(--ghost-dim);
    }
</style>
