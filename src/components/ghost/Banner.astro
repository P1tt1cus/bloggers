---
// Index hero (spec ¬ß01, large banner). Markup is fully visible by default ‚ÄĒ
// the motion layer opts IN to a boot reveal; a JS failure can never blank it.
import GhostSprite from './GhostSprite.astro';

interface Props {
    count: number;
}

const { count } = Astro.props;

const LOGO = `‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ
‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ       ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĎ      ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ       ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ ‚Ėą‚Ėą‚ēĎ      ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ
‚Ėą‚Ėą‚ēĎ      ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ       ‚Ėą‚Ėą‚ēĎ    ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ
‚ēö‚ēź‚ēĚ      ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēĚ       ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ`;

// Two-tone ANSI shadow: blocks lit, box-drawing shadow chars faint.
const logoHtml = LOGO.split('\n')
    .map((line) =>
        line.replace(/(‚Ėą+)|([‚ēĒ‚ēó‚ēö‚ēĚ‚ēź‚ēĎ]+)/g, (m, blocks) =>
            blocks ? `<span class="lit">${m}</span>` : `<span class="shade">${m}</span>`,
        ),
    )
    .join('\n');
---

<header class="ghost-banner" data-ghost-banner>
    <h1 class="visually-hidden">Pitticus ‚ÄĒ terminal blog</h1>
    <div class="banner-art">
        <pre class="logo" aria-hidden="true" data-ghost-boot-line set:html={logoHtml} />
        <GhostSprite caption />
    </div>
    <div class="boot">
        <p data-ghost-boot-line>pitticus v2.0.0 ‚ÄĒ haunted terminal blog</p>
        <p data-ghost-boot-line>ghost-mode enabled ¬∑ {count} transmissions</p>
        <p class="boot-rule" data-ghost-boot-line aria-hidden="true">‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ</p>
        <p data-ghost-boot-line>select a transmission, or press <kbd>?</kbd> for help</p>
    </div>
    <p class="sigil-line" data-ghost-boot-line>
        <span class="sigil" aria-hidden="true">‚ĆĀ</span> awaiting selection <span data-ghost-cursor></span>
    </p>
    <p class="scan-line" data-ghost-boot-line>
        <span class="scan-result" data-ghost-boot-status><span class="ok" aria-hidden="true">‚úď</span> {count} transmissions ¬∑ 8ms</span>
    </p>
</header>

<style>
    .ghost-banner {
        padding: 2.5rem 0 0.5rem;
    }

    .banner-art {
        display: flex;
        align-items: flex-end;
        gap: 3rem;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
    }

    .logo {
        font-family: var(--ghost-font);
        font-size: clamp(7px, 1.4vw, 13px);
        line-height: 1.2;
        color: var(--ghost-fg);
    }

    .logo :global(.lit) {
        color: var(--ghost-fg);
    }

    .logo :global(.shade) {
        color: var(--ghost-faint);
    }

    .boot p {
        color: var(--ghost-dim);
        margin: 0.1rem 0;
    }

    .boot kbd {
        font-family: var(--ghost-font);
        color: var(--ghost-accent);
    }

    .boot-rule {
        color: var(--ghost-faint);
    }

    .sigil-line {
        margin-top: 1.25rem;
        color: var(--ghost-fg);
    }

    .sigil {
        color: var(--ghost-accent);
    }

    .scan-line {
        margin-top: 0.25rem;
        color: var(--ghost-dim);
        min-height: 1.6em;
    }

    .scan-line .ok {
        color: var(--ghost-ok);
    }

    @media (max-width: 640px) {
        .banner-art {
            display: none;
        }

        .ghost-banner {
            padding-top: 1.25rem;
        }
    }
</style>
