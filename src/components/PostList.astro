---
import BlogPost from './BlogPost.astro';
import { formatDate } from '../lib/transmissions';
import type { Transmission, PostTransmission } from '../lib/transmissions';

interface Props {
    transmissions: Transmission[];
}

const { transmissions } = Astro.props;

const posts = transmissions.filter((t): t is PostTransmission => t.kind === 'post');
const rendered = await Promise.all(
    posts.map(async (t) => ({ slug: t.slug, Content: (await t.entry.render()).Content })),
);
---

<div id="post-list">
    <header>
        <div class="vim-info">
            <span class="filename">index.md</span>
            <span class="file-type">[markdown]</span>
        </div>
        <h1 class="vim-header"># Pitticus's Blog</h1>
    </header>
    <section class="posts">
        {transmissions.map(t => (
            <BlogPost
                title={t.title}
                date={formatDate(t.date)}
                slug={t.slug}
                description={t.description}
                isExternal={t.kind === 'artifact'}
                href={t.href}
            />
        ))}
    </section>
    {rendered.map(({ slug, Content }) => (
        <template id={`tpl-${slug}`}><Content /></template>
    ))}
</div>

<style>
    .vim-info {
        color: var(--nvim-gray);
        font-size: 0.9rem;
        margin-bottom: 1rem;
        display: flex;
        gap: 1rem;
        align-items: center;
        height: 24px;
    }

    .filename {
        color: var(--nvim-blue);
    }

    .vim-header {
        color: var(--nvim-green);
        font-size: 1.8rem;
        margin-bottom: 2rem;
        height: 48px;
        line-height: 48px;
    }

    #post-list.hidden {
        display: none;
    }
</style>
